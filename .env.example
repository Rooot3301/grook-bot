# Token du bot Discord (obligatoire)
DISCORD_TOKEN=your_token_here

# Clé API VirusTotal (optionnel - laisser vide pour désactiver)
VIRUSTOTAL_API_KEY=

# Intervalle de rotation du rich presence en minutes (défaut : 5)
PRESENCE_INTERVAL_MIN=5

# Niveau de log : debug | info | warn | error (défaut : info)
LOG_LEVEL=info

# ID du serveur de développement pour un déploiement instantané des slash commands
# (laisser vide pour le déploiement global — peut prendre jusqu'à 1h)
DEV_GUILD_ID=

# Votre ID Discord — utilisé pour la commande /credit (mention du créateur)
BOT_OWNER_ID=

# Webhook Discord pour les notifications CLI (start/stop/update/erreurs)
# Créez un webhook dans les paramètres d'un salon → Intégrations → Webhooks
DISCORD_WEBHOOK_URL=
